{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "C++: g++.exe 빌드 및 디버그 활성 파일",
            "type": "cppdbg",
            "request": "launch",
            "program": "${fileDirname}\\${fileBasenameNoExtension}.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "C:\\msys64\\ucrt64\\bin\\gdb.exe", // ⬅️ 여기에 실제 gdb.exe가 있는 경로를 적어주세요!
            "setupCommands": [
                {
                    "description": "gdb에 대해 자동 서식 지정 사용",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "C/C++: g++.exe build active file"
        }
    ]
}